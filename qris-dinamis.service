[Unit]
Description=QrisDinamis
ConditionPathExists=/var/www/qris/build
Wants=network.target
After=network.target
StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=/var/www/qris/build
ExecStart=/usr/bin/node/ /var/www/qris/build/bin/server.js

# Speed up Shutdown & Restart Cycles
KillSignal=SIGTERM
TimeoutStopSec=4s
SendSIGKILL=yes

# Restart Policy
Restart=on-failure
RestartSec=2s

[Install]
WantedBy=multi-user.target